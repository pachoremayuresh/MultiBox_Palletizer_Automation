<?xml version="1.0" encoding="utf-8"?>
<vdef:Visualization id="Palletizer" autoUpdate="true" xmlns:vdef="http://www.br-automation.com/iat2015/visualizationDefinition/v2">
  <StartPage pageRefId="Operate" />
  <Pages>
    <Page refId="Operate" />
    <Page refId="Alarm" />
    <Page refId="Service" />
  </Pages>
  <Navigations />
  <BindingsSets>
    <BindingsSet refId="Service_binding" />
    <BindingsSet refId="Alarm_binding" />
    <BindingsSet refId="Operate_binding" />
    <BindingsSet refId="Top_binding" />
  </BindingsSets>
  <EventBindingsSets />
  <Dialogs />
  <Contents>
    <Content refId="Operate" />
  </Contents>
  <SnippetsSets />
  <VariablesSets />
  <ExpressionsSets />
  <Configurations>
    <Configuration key="activityCount" value="false" />
    <Gestures>
      <!--<SystemGesture1 touchPoints="2" />
		  <SystemGesture2 touchPoints="2" />
		  <SystemGesture3 touchPoints="2" />-->
    </Gestures>
    <VirtualKeyboards>
      <!--<InputProcessing onKeyDown="true" />-->
    </VirtualKeyboards>
  </Configurations>
</vdef:Visualization>