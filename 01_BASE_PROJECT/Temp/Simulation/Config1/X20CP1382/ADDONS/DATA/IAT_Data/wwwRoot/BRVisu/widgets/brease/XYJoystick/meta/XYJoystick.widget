		<Categories>
			<Category name="Category">Numeric</Category>
		</Categories>
		<Descriptions>
			<Description name="short">Schieberegler auf welcher in X oder Y Richtung verschoben werden kann</Description>
			<Description name="de">Ermöglicht dem Benutzer numerische Werte mit einem Schiebeschalter in X oder Y Richtung zu verändern</Description>
			<Description name="en">Enables the user to change numeric values by a slider in X or Y direction</Description>
		</Descriptions>
		<Inheritance>
			<Class level="0">widgets.brease.XYJoystick</Class>
			<Class level="1">brease.core.BaseWidget</Class>
		</Inheritance>
