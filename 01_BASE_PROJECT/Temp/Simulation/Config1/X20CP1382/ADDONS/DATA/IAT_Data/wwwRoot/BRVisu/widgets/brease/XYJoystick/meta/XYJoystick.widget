			<Parent>*</Parent>
		</Parents>
		<Children>
		</Children>
		<Methods>
			<Method name="LockXAxis" read="false">
				<Description>If true, locks the XAxis</Description>
				<Arguments>
					<Argument name="value" type="Boolean" index="0" required="true"/>
				</Arguments>
			</Method>
			<Method name="LockYAxis" read="false">
				<Description>If true, locks the YAxis</Description>
				<Arguments>
					<Argument name="value" type="Boolean" index="0" required="true"/>
				</Arguments>
			</Method>
			<Method name="Focus" read="false">
				<Description>Sets focus on the widget element, if it can be focused and keyboardOperation=true</Description>
			</Method>
			<Method name="GetXValue" read="true">
				<Description>Returns xValue.</Description>
				<Result type="Number"/>
			</Method>
			<Method name="GetYValue" read="true">
				<Description>Returns yValue.</Description>
				<Result type="Number"/>
			</Method>
